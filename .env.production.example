# This file is a template only. Copy it to .env.production inside the VM,
# replace every value, and set permissions to 0600. Do not commit the real file.
APP_IMAGE=sight-words:initial
POSTGRES_DB=sight_words
POSTGRES_USER=sight_words
POSTGRES_PASSWORD=replace-with-a-generated-password
SESSION_SECRET=replace-with-a-generated-session-secret

# Set during the Cloudflare Tunnel stage. The tunnel profile is not started
# until then, so this may remain empty for the initial private deployment.
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest
