{
  "name": "dan-sight-words",
  "version": "2.0.0",
  "private": true,
  "description": "Dockerized sight words game with accounts, Postgres progress, and staged rewards.",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node server/server.js",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "start": "node server/server.js",
    "migrate": "node server/migrate.js",
    "check": "node --check server/server.js && node --check server/auth.js && node --check server/progress.js && node --check server/content.js && tsc --noEmit",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "node --test",
    "test:frontend": "vitest run",
    "coverage": "npm run coverage:backend && npm run coverage:frontend",
    "coverage:backend": "node --test --experimental-test-coverage --test-coverage-include=server/auth.js --test-coverage-include=server/content.js --test-coverage-include=server/progress.js --test-coverage-lines=100 --test-coverage-branches=100 --test-coverage-functions=100",
    "coverage:frontend": "vitest run --coverage"
  },
  "dependencies": {
    "connect-pg-simple": "^10.0.0",
    "express": "^5.1.0",
    "express-session": "^1.18.1",
    "pg": "^8.13.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
